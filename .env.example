# PostgreSQL / TimescaleDB
POSTGRES_DB=mqttstat
POSTGRES_USER=mqttstat
POSTGRES_PASSWORD=mqttstat
POSTGRES_PORT=5432

# Service ports on the host machine
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Frontend build-time API URL
# For local Docker usage, keep this at localhost.
VITE_API_BASE_URL=http://localhost:8000

# Backend database connection string (used by backend and migrate service)
DATABASE_URL=postgresql://mqttstat:mqttstat@postgres-timescaledb:5432/mqttstat

# MQTT broker connectivity
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_BROKER_USER=
MQTT_BROKER_PASS=
MQTT_CLIENT_ID=mqttstat-backend

# Topic mapping file loaded by backend at startup.
MQTT_TOPIC_MAP_PATH=config/topic_mappings.yaml
